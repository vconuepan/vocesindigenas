{
  "plansDirectory": ".plans",
  "permissions": {
    "allow": [
      "Bash(npm run db:migrate:resolve*)",
      "Bash(npm run images:*)",
      "WebFetch(domain:actuallyrelevant.news)",
      "WebFetch(domain:render.com)",
      "WebFetch(domain:platform.openai.com)",
      "WebFetch(domain:cookbook.openai.com)",
      "WebFetch(domain:developers.openai.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.diffbot.com)",
      "WebFetch(domain:next-wiki.useplunk.com)"
    ],
    "deny": [
      "Bash(npx prisma*)",
      "Bash(npm run db:migrate --prefix *)"
    ]
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": false
  }
}
