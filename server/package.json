{
  "name": "actually-relevant-server",
  "version": "0.1.0",
  "type": "module",
  "description": "Backend API for Actually Relevant news curation platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node --max-old-space-size=384 dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:migrate:create": "prisma migrate dev --create-only",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:resolve": "prisma migrate resolve",
    "db:migrate:status": "prisma migrate status",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:populate-issue-content": "tsx src/scripts/migrate/populate-issue-content.ts",
    "migration:backfill-title-label": "tsx src/scripts/migrations/backfill-title-label.ts",
    "migration:backfill-title-label:test": "tsx src/scripts/migrations/backfill-title-label.ts --test",
    "migration:backfill-quote-attribution": "tsx src/scripts/migrations/backfill-quote-attribution.ts",
    "migration:backfill-quote-attribution:test": "tsx src/scripts/migrations/backfill-quote-attribution.ts --test",
    "migration:backfill-relevance-summary": "tsx src/scripts/migrations/backfill-relevance-summary.ts",
    "migration:backfill-relevance-summary:test": "tsx src/scripts/migrations/backfill-relevance-summary.ts --test",
    "migration:backfill-emotion-tag": "tsx src/scripts/migrations/backfill-emotion-tag.ts",
    "migration:backfill-emotion-tag:test": "tsx src/scripts/migrations/backfill-emotion-tag.ts --test",
    "migration:backfill-embeddings": "tsx src/scripts/migrations/backfill-embeddings.ts",
    "migration:backfill-embeddings:test": "tsx src/scripts/migrations/backfill-embeddings.ts --test"
  },
  "dependencies": {
    "@atproto/api": "^0.18.20",
    "@langchain/core": "^1.1.17",
    "@langchain/openai": "^1.2.3",
    "@mozilla/readability": "^0.6.0",
    "@napi-rs/canvas": "^0.1.89",
    "@prisma/client": "^6.0.0",
    "archiver": "^7.0.1",
    "axios": "^1.13.4",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.4.0",
    "feed": "^5.2.0",
    "helmet": "^8.1.0",
    "jsdom": "^27.4.0",
    "jsonwebtoken": "^9.0.3",
    "langchain": "^1.2.15",
    "masto": "^7.10.1",
    "node-cron": "^3.0.3",
    "pdfkit": "^0.17.2",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "rss-parser": "^3.13.0",
    "zod": "^3.23.8",
    "zod-openapi": "^4.2.4"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsdom": "^27.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.4",
    "@types/supertest": "^6.0.2",
    "prisma": "^6.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^4.0.18"
  }
}
