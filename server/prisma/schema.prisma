generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// --- Enums ---

enum StoryStatus {
  fetched
  pre_analyzed
  analyzed
  selected
  published
  rejected
  trashed
}

enum EmotionTag {
  uplifting
  frustrating
  scary
  calm
}

enum FeedRegion {
  north_america
  western_europe
  eastern_europe
  middle_east_north_africa
  sub_saharan_africa
  south_southeast_asia
  pacific
  latin_america
  global
}

enum ContentStatus {
  draft
  published
}


// --- Core Tables ---

model Story {
  id                     String       @id @default(uuid())
  sourceUrl              String       @unique @map("source_url")
  sourceTitle            String       @map("source_title")
  sourceContent          String       @map("source_content")
  sourceDatePublished    DateTime?    @map("source_date_published")
  feedId                 String       @map("feed_id")
  feed                   Feed         @relation(fields: [feedId], references: [id])
  issueId                String?      @map("issue_id")
  issue                  Issue?       @relation(fields: [issueId], references: [id])
  status                 StoryStatus  @default(fetched)
  dateCrawled            DateTime     @default(now()) @map("date_crawled")
  datePublished          DateTime?    @map("date_published")
  relevancePre           Int?         @map("relevance_pre")
  relevance              Int?
  emotionTag             EmotionTag?  @map("emotion_tag")
  slug                   String?      @unique
  title                  String?
  titleLabel             String?      @map("title_label")
  summary                String?
  quote                  String?
  quoteAttribution       String?      @map("quote_attribution")
  marketingBlurb         String?      @map("marketing_blurb")
  relevanceReasons       String?      @map("relevance_reasons")
  relevanceSummary       String?      @map("relevance_summary")
  antifactors            String?
  relevanceCalculation   String?      @map("relevance_calculation")
  crawlMethod            String?      @map("crawl_method")
  imageUrl               String?      @map("image_url")
  titleEn                String?      @map("title_en")
  titleLabelEn           String?      @map("title_label_en")
  summaryEn              String?      @map("summary_en")
  quoteEn                String?      @map("quote_en")
  marketingBlurbEn       String?      @map("marketing_blurb_en")
  relevanceSummaryEn     String?      @map("relevance_summary_en")
  embedding              Unsupported("vector(1536)")?
  embeddingContentHash   String?      @db.VarChar(64) @map("embedding_content_hash")
  embeddingGeneratedAt   DateTime?    @map("embedding_generated_at")
  clusterId              String?      @map("cluster_id")
  cluster                StoryCluster? @relation("ClusterMember", fields: [clusterId], references: [id])
  primaryOfCluster       StoryCluster? @relation("ClusterPrimary")
  blueskyPosts           BlueskyPost[]
  mastodonPosts          MastodonPost[]
  twitterPosts           TwitterPost[]
  instagramPosts         InstagramPost[]
  linkedinPosts          LinkedInPost[]
  communityPosts         CommunityPost[]
  createdAt              DateTime     @default(now()) @map("created_at")
  updatedAt              DateTime     @updatedAt @map("updated_at")

  @@index([status, dateCrawled])
  @@index([feedId])
  @@index([status, relevancePre])
  @@index([status, relevance])
  @@index([datePublished])
  @@index([issueId])
  @@index([clusterId])
  @@map("stories")
}

model StoryCluster {
  id             String   @id @default(uuid())
  primaryStoryId String?  @unique @map("primary_story_id")
  primaryStory   Story?   @relation("ClusterPrimary", fields: [primaryStoryId], references: [id])
  stories        Story[]  @relation("ClusterMember")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("story_clusters")
}

model Feed {
  id                 String    @id @default(uuid())
  title              String
  rssUrl             String    @unique @map("rss_url")
  url                String?
  displayTitle       String?   @map("display_title")
  language           String    @default("en")
  region             FeedRegion?
  issueId            String    @map("issue_id")
  issue              Issue     @relation(fields: [issueId], references: [id])
  active             Boolean   @default(true)
  crawlIntervalHours Int       @default(24) @map("crawl_interval_hours")
  lastCrawledAt      DateTime? @map("last_crawled_at")
  lastCrawlError          String?   @map("last_crawl_error")
  lastCrawlErrorAt        DateTime? @map("last_crawl_error_at")
  consecutiveFailedCrawls Int       @default(0) @map("consecutive_failed_crawls")
  consecutiveEmptyCrawls  Int       @default(0) @map("consecutive_empty_crawls")
  lastSuccessfulCrawlAt   DateTime? @map("last_successful_crawl_at")
  lastEtag                String?   @map("last_etag")
  lastModified            String?   @map("last_modified")
  lastCrawlResult         String?   @map("last_crawl_result")
  htmlSelector            String?   @map("html_selector")
  stories            Story[]
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@map("feeds")
}

model Issue {
  id                 String   @id @default(uuid())
  name               String
  slug               String   @unique
  description        String   @default("")
  promptFactors      String   @default("") @map("prompt_factors")
  promptAntifactors  String   @default("") @map("prompt_antifactors")
  promptRatings      String   @default("") @map("prompt_ratings")
  parentId           String?  @map("parent_id")
  parent             Issue?   @relation("IssueHierarchy", fields: [parentId], references: [id])
  children           Issue[]  @relation("IssueHierarchy")
  intro              String   @default("")
  evaluationIntro    String   @default("") @map("evaluation_intro")
  evaluationCriteria String   @default("") @map("evaluation_criteria")
  makeADifference    String   @default("") @map("make_a_difference")
  minPreRating       Int?     @map("min_pre_rating")
  feeds              Feed[]
  stories            Story[]
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("issues")
}

model Newsletter {
  id        String           @id @default(uuid())
  title     String
  content   String           @default("")
  html      String           @default("")
  storyIds          String[]         @map("story_ids")
  selectedStoryIds  String[]         @default([]) @map("selected_story_ids")
  status            ContentStatus    @default(draft)
  sends     NewsletterSend[]
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@map("newsletters")
}

enum NewsletterSendStatus {
  draft
  scheduled
  sending
  sent
  failed
}

model NewsletterSend {
  id              String               @id @default(uuid())
  newsletterId    String               @map("newsletter_id")
  newsletter      Newsletter           @relation(fields: [newsletterId], references: [id], onDelete: Cascade)
  plunkCampaignId String?              @map("plunk_campaign_id")
  isTest          Boolean              @default(false) @map("is_test")
  status          NewsletterSendStatus @default(draft)
  htmlContent     String               @map("html_content")
  stats           Json                 @default("{}")
  errorMessage    String?              @map("error_message")
  sentAt          DateTime?            @map("sent_at")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  @@index([newsletterId])
  @@index([plunkCampaignId])
  @@map("newsletter_sends")
}

model Podcast {
  id            String        @id @default(uuid())
  title         String
  description   String        @default("")
  script        String        @default("")
  audioUrl      String?       @map("audio_url")
  duration      Int?          // duración en segundos
  episodeNumber Int?          @map("episode_number")
  storyIds      String[]      @map("story_ids")
  status        ContentStatus @default(draft)
  publishedAt   DateTime?     @map("published_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@map("podcasts")
}

model JobRun {
  id              String    @id @default(uuid())
  jobName         String    @unique @map("job_name")
  lastStartedAt   DateTime? @map("last_started_at")
  lastCompletedAt DateTime? @map("last_completed_at")
  lastError       String?   @map("last_error")
  enabled         Boolean   @default(true)
  cronExpression  String    @map("cron_expression")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("job_runs")
}

// --- Bluesky Tables ---

model BlueskyPost {
  id               String    @id @default(uuid())
  storyId          String    @unique @map("story_id")
  story            Story     @relation(fields: [storyId], references: [id])
  postUri          String?   @unique @map("post_uri")
  postCid          String?   @map("post_cid")
  status           String    @default("draft") // draft | published | failed
  postText         String    @map("post_text")
  error            String?
  publishedAt      DateTime? @map("published_at")
  likeCount        Int       @default(0) @map("like_count")
  repostCount      Int       @default(0) @map("repost_count")
  replyCount       Int       @default(0) @map("reply_count")
  quoteCount       Int       @default(0) @map("quote_count")
  metricsUpdatedAt DateTime? @map("metrics_updated_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([publishedAt])
  @@map("bluesky_posts")
}

// --- Mastodon Tables ---

model MastodonPost {
  id               String    @id @default(uuid())
  storyId          String    @unique @map("story_id")
  story            Story     @relation(fields: [storyId], references: [id])
  statusId         String?   @unique @map("status_id")
  statusUrl        String?   @map("status_url")
  status           String    @default("draft") // draft | published | failed
  postText         String    @map("post_text")
  error            String?
  publishedAt      DateTime? @map("published_at")
  favouriteCount   Int       @default(0) @map("favourite_count")
  boostCount       Int       @default(0) @map("boost_count")
  replyCount       Int       @default(0) @map("reply_count")
  metricsUpdatedAt DateTime? @map("metrics_updated_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([publishedAt])
  @@map("mastodon_posts")
}
// --- Twitter Tables ---

model TwitterPost {
  id               String    @id @default(uuid())
  storyId          String    @unique @map("story_id")
  story            Story     @relation(fields: [storyId], references: [id])
  tweetId          String?   @unique @map("tweet_id")
  tweetUrl         String?   @map("tweet_url")
  status           String    @default("draft") // draft | published | failed
  postText         String    @map("post_text")
  error            String?
  imageUrl         String?   @map("image_url")
  publishedAt      DateTime? @map("published_at")
  likeCount        Int       @default(0) @map("like_count")
  retweetCount     Int       @default(0) @map("retweet_count")
  replyCount       Int       @default(0) @map("reply_count")
  quoteCount       Int       @default(0) @map("quote_count")
  metricsUpdatedAt DateTime? @map("metrics_updated_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([publishedAt])
  @@map("twitter_posts")
}
// --- Instagram Tables ---

model InstagramPost {
  id               String    @id @default(uuid())
  storyId          String    @unique @map("story_id")
  story            Story     @relation(fields: [storyId], references: [id])
  instagramPostId  String?   @unique @map("instagram_post_id")
  permalink        String?
  status           String    @default("draft")
  caption          String
  imageUrl         String    @map("image_url")
  slideUrls        String[]  @default([]) @map("slide_urls")
  error            String?
  publishedAt      DateTime? @map("published_at")
  likeCount        Int       @default(0) @map("like_count")
  commentCount     Int       @default(0) @map("comment_count")
  metricsUpdatedAt DateTime? @map("metrics_updated_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([publishedAt])
  @@map("instagram_posts")
}
// --- LinkedIn Tables ---

model LinkedInPost {
  id               String    @id @default(uuid())
  storyId          String    @unique @map("story_id")
  story            Story     @relation(fields: [storyId], references: [id])
  linkedinPostId   String?   @unique @map("linkedin_post_id")
  postUrl          String?   @map("post_url")
  status           String    @default("draft")
  postText         String    @map("post_text")
  error            String?
  publishedAt      DateTime? @map("published_at")
  likeCount        Int       @default(0) @map("like_count")
  commentCount     Int       @default(0) @map("comment_count")
  impressionCount  Int       @default(0) @map("impression_count")
  metricsUpdatedAt DateTime? @map("metrics_updated_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([publishedAt])
  @@map("linkedin_posts")
}

// --- Analytics ---

model PageView {
  id    String   @id @default(uuid())
  path  String   @db.VarChar(500)
  date  DateTime // stored as midnight UTC (day-level granularity)
  count Int      @default(1)

  @@unique([path, date])
  @@index([date])
  @@map("page_views")
}

// --- Subscription Tables ---

model PendingSubscription {
  id             String    @id @default(uuid())
  email          String
  token          String    @unique
  plunkContactId String?   @map("plunk_contact_id")
  confirmedAt    DateTime? @map("confirmed_at")
  expiresAt      DateTime  @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([token])
  @@index([email])
  @@map("pending_subscriptions")
}


// --- Feedback Tables ---

enum FeedbackCategory {
  general
  bug
  suggestion
  other
}

enum FeedbackStatus {
  unread
  read
  archived
}

model Feedback {
  id        String           @id @default(uuid())
  category  FeedbackCategory
  message   String
  email     String?
  status    FeedbackStatus   @default(unread)
  ipHash    String           @map("ip_hash")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@index([status])
  @@index([createdAt])
  @@map("feedback")
}

// --- Auth Tables ---

enum UserType {
  ADMIN
  EMPRESA
  COMUNIDAD_LIDER
  VEEDOR
}

model User {
  id            String             @id @default(uuid())
  email         String             @unique
  name          String
  passwordHash  String
  userType      UserType           @default(VEEDOR)
  verified      Boolean            @default(false)
  freeLicense   Boolean            @default(false)
  comunidadId   String?
  memberships       CommunityMember[]
  digestExclusions  DigestExclusion[]
  posts             CommunityPost[]
  refreshTokens     RefreshToken[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@map("users")
}

// --- Community Tables ---

enum CommunityType {
  PUEBLO
  TERRITORIO
  CAUSA
}

model Community {
  id          String            @id @default(uuid())
  slug        String            @unique
  name        String
  description String
  type        CommunityType
  region      String?
  imageUrl    String?           @map("image_url")
  issueIds    String[]          @map("issue_ids")
  keywords    String[]          @default([]) @map("keywords")
  active      Boolean           @default(true)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  members          CommunityMember[]
  digestExclusions DigestExclusion[]
  posts            CommunityPost[]

  @@index([slug])
  @@map("communities")
}

model CommunityMember {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  communityId String    @map("community_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  joinedAt    DateTime  @default(now()) @map("joined_at")

  @@unique([userId, communityId])
  @@index([communityId])
  @@map("community_members")
}

model DigestExclusion {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  communityId String    @map("community_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@unique([userId, communityId])
  @@index([communityId])
  @@map("digest_exclusions")
}

model CommunityPost {
  id          String    @id @default(uuid())
  storyId     String    @map("story_id")
  userId      String    @map("user_id")
  communityId String    @map("community_id")
  content     String
  story       Story     @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([communityId, createdAt])
  @@index([storyId])
  @@map("community_posts")
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyId  String    @map("family_id")
  expiresAt DateTime  @map("expires_at")
  rotatedAt DateTime? @map("rotated_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([expiresAt])
  @@index([familyId])
  @@map("refresh_tokens")
}

model MagicLink {
  id         String    @id @default(uuid())
  email      String
  token      String    @unique
  expiresAt  DateTime  @map("expires_at")
  usedAt     DateTime? @map("used_at")
  redirectTo String?   @map("redirect_to")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([token])
  @@index([expiresAt])
  @@map("magic_links")
}

// --- Spotlight (En Foco) ---
// Editorial tool: configure a topic of the moment (e.g. "Foro Permanente ONU 2025")
// with keywords that filter stories, shown as a rotating band on the homepage.

model Spotlight {
  id        String    @id @default(cuid())
  label     String                         // Display name: "Foro Permanente ONU 2025"
  keywords  String[]  @default([])         // Keywords for ILIKE story matching
  isActive  Boolean   @default(true) @map("is_active")
  startsAt  DateTime? @map("starts_at")    // Optional window (null = always)
  endsAt    DateTime? @map("ends_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("spotlights")
}
