# To generate links, e.g. to confirm newsletter subscriptions
API_URL="https://actually-relevant-api.onrender.com"

# Site URL for links in posts
SITE_URL="https://actuallyrelevant.news"

# Frontend URL for CORS
FRONTEND_URL="https://actuallyrelevant.news"
# Server port (optional, defaults to 3001 locally, Render sets automatically)
PORT=3001
JWT_SECRET=[at least 32 characters]
# PUBLIC_API_KEY=optional-api-key-for-public-access-of-protected-routes

# Database (PostgreSQL with pgvector)
DATABASE_URL="postgresql://user:password@localhost:5432/actually_relevant?schema=public"

# Services
OPENAI_API_KEY="sk-..."
DIFFBOT_TOKEN=your_token_here
PIPFEED_API_KEY=

PLUNK_SECRET_KEY=sk_...
PLUNK_PUBLIC_KEY=pk_...
PLUNK_FROM_EMAIL=newsletter@actuallyrelevant.news  # Must be a verified sender in Plunk
PLUNK_TEST_SEGMENT_ID=

BLUESKY_AUTO_POST_ENABLED=true
BLUESKY_HANDLE=actuallyrelevant.bsky.social
BLUESKY_APP_PASSWORD=

MASTODON_AUTO_POST_ENABLED=true
MASTODON_URL=https://mastodon.social
MASTODON_TOKEN=""