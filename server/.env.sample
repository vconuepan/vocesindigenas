# Database (PostgreSQL with pgvector)
DATABASE_URL="postgresql://user:password@localhost:5432/actually_relevant?schema=public"

# OpenAI API key (required for LLM analysis)
OPENAI_API_KEY="sk-..."

# ─── PipFeed API (optional) ───────────────────────────────────────────
# Third-party article extraction fallback via RapidAPI.
# Only used when CSS selector and Readability both fail.
# Get a key at: https://rapidapi.com/pipfeed-pipfeed-default/api/news-article-data-extract-and-summarization1
# PIPFEED_API_KEY=

# Frontend URL for CORS (production only)
FRONTEND_URL=""

# Server port (optional, defaults to 3001 locally, Render sets automatically)
PORT=3001

# Authentication
JWT_SECRET=[at least 32 characters]
PUBLIC_API_KEY=optional-api-key-for-public-content-access